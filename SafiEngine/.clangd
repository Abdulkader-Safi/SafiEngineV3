# SafiEngine clangd config.
# The engine is C11; the only C++ translation unit is the cimgui bridge.

CompileFlags:
  Add: [-std=c11, -Wall, -Wextra, -Wpedantic]
  Compiler: clang

---
If:
  PathMatch: .*\.h$
CompileFlags:
  Add: [-xc]

---
If:
  PathMatch: .*\.(cpp|cc|cxx)$
CompileFlags:
  Remove: [-std=c11]
  Add: [-std=c++17, -xc++]
